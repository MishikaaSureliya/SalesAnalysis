@{
    ViewData["Title"] = "Dashboard";
    var message = Context.Request.Query["message"].ToString();
}

@if (!string.IsNullOrEmpty(message))
{
    if (message.Contains("0"))
    {
        <div class="alert alert-danger text-center">@message</div>
    }
    else
    {
        <div class="alert alert-success text-center">@message</div>
    }
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
.dashboard-header {
    background: linear-gradient(to right, #2c3e50, #4ca1af);
    color: white;
    padding: 20px;
    border-radius: 10px;
}
.card {
    border-radius: 10px;
}
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="dashboard-header text-center mb-4">
        <h2>E-Commerce Sales Analysis & Forecasting Dashboard</h2>
    </div>

    <!-- Upload CSV -->
    <form method="post" enctype="multipart/form-data" asp-controller="Sales" asp-action="UploadCSV" onsubmit="showLoader()">
        <script>
function showLoader() {
    $("#loaderOverlay").show();
}
</script>
        <div class="row mb-4">
            <div class="col-md-4">
                <input type="file" name="file" class="form-control" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary">Upload CSV</button>
            </div>
        </div>
    </form>

    <div id="loaderOverlay" style="display:none;">
    <div class="loader"></div>
    <p>Loading Dashboard...</p>
</div>

    <!-- Filters -->
    <div class="row mb-3">
        <div class="col-md-3">
            <select id="regionFilter" class="form-control">
                <option value="">All Regions</option>
                <option value="East">East</option>
                <option value="West">West</option>
                <option value="North">North</option>
                <option value="South">South</option>
            </select>
        </div>

        <div class="col-md-3">
            <select id="categoryFilter" class="form-control">
                <option value="">All Categories</option>
                <option value="Electronics">Electronics</option>
                <option value="Furniture">Furniture</option>
                <option value="Stationery">Stationery</option>
            </select>
        </div>

        <div class="col-md-2">
            <button type="button" class="btn btn-success" onclick="loadDashboard()">Apply Filter</button>
        </div>

        <div class="col-md-2">
           <button type="button" class="btn btn-secondary" onclick="resetFilter()">Reset</button>
        </div>
    </div>

    @if (ViewBag.NoData == true)
    {
        <div class="text-center mt-5">
            <h3>No Records Available</h3>
            <p>Please upload CSV file to view dashboard</p>
        </div>
    }
    else
    {
        <!-- KPI Cards -->
        <div class="row text-center">
            <div class="col-md-3">
                <div class="card p-3 shadow">
                    <h5>Total Revenue</h5>
                    <h3 id="totalRevenue"></h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow">
                    <h5>Total Orders</h5>
                    <h3 id="totalOrders"></h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow">
                    <h5>Top Region</h5>
                    <h3 id="topRegion"></h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow">
                    <h5>Top Category</h5>
                    <h3 id="topCategory"></h3>
                </div>
            </div>
        </div>

        <!-- Charts Row 1 -->
        <div class="row mt-4">
            <div class="col-md-4">
                <h5>Sales by Region</h5>
                <canvas id="regionChart"></canvas>
            </div>

            <div class="col-md-4">
                <h5>Monthly Sales Trend</h5>
                <canvas id="monthlyChart"></canvas>
            </div>

            <div class="col-md-4">
                <h5>Sales by Category</h5>
                <canvas id="categoryChart"></canvas>
            </div>
        </div>

        <!-- Charts Row 2 -->
        <div class="row mt-4">
            <div class="col-md-6">
                <h5>Sales Forecast</h5>
                <canvas id="forecastChart"></canvas>
            </div>

            <div class="col-md-6">
                <h5>Correlation Heatmap</h5>
                <canvas id="heatmapChart" width="600" height="450"></canvas>
            </div>
        </div>
    }

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="~/js/dashboard.js"></script>

<script>
function showLoader() {
    $("#loaderOverlay").show();
}

function hideLoader() {
    $("#loaderOverlay").hide();
}
</script>

@if (ViewBag.NoData == false)
{
    <script>
        window.onload = function () {
            loadDashboard();
        };
    </script>
}